{
  "name": "${matches(request.uri.path, '^/sensitive')}",
  "condition": "${matches(request.uri.path, '^/sensitive')}",
  "monitor": true,
  "timer": true,
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        {
          "name": "MFAFilter",
          "type": "ScriptableFilter",
          "config": {
            "type": "application/x-groovy",
            "file": "mfa.groovy",
            "args": {
              "requiredChain": "totp",
              "timeoutSec": 20,
              "location": "${system['openam']}/XUI/#login&service=totp&ForceAuth=true&goto="
             }
          }
        }
        
      ],
      "handler": "EndpointHandler"
    }
  },
  "heap": []
}